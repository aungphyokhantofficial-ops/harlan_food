// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}


// 1. Admin & Authentication Layer
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String   // Hashed password
  role      String   @default("ADMIN") 
  createdAt DateTime @default(now())
}

// 2. Menu Management (Harlan's Dining & Wine Selection)
model Category {
  id        Int        @id @default(autoincrement())
  name      String     @unique // "Main Menu", "Wine List", "Desserts"
  slug      String     @unique // URL အတွက် (ဥပမာ- wine-cellar)
  type      String     @default("FOOD") // "FOOD" သို့မဟုတ် "WINE"
  foodItems FoodItem[]
}

model FoodItem {
  id          Int      @id @default(autoincrement())
  name        String
  description String?  
  price       Float?   // အချို့ Fine Dining Menu များတွင် ဈေးနှုန်းမပြပါ
  image       String?
  isFeatured  Boolean  @default(false) // Home page မှာပြရန်
  isAvailable Boolean  @default(true)  // ပစ္စည်းပြတ်ပါက ပိတ်ရန်
  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id])
}

// 3. Event Spaces & Private Dining (Harlan's Core Experience)
model Venue {
  id          Int      @id @default(autoincrement())
  name        String   // "The Terrace", "Private Room A"
  slug        String   @unique
  description String?  
  capacity    Int      // ဧည့်သည်ဆံ့ဝင်ဦးရေ
  image       String?
  inquiries   Inquiry[]
}

// 4. Inquiries & Reservations (Customer Leads)
model Inquiry {
  id             Int      @id @default(autoincrement())
  type           String   // "RESERVATION" သို့မဟုတ် "EVENT"
  name           String
  email          String
  phone          String
  eventDate      DateTime
  guestCount     Int
  message        String?  
  status         String   @default("PENDING") // "PENDING", "CONFIRMED", "CANCELLED"
  venueId        Int?
  venue          Venue?   @relation(fields: [venueId], references: [id])
  createdAt      DateTime @default(now())
}



// 6. Gallery (Brand Image)
model Gallery {
  id       Int     @id @default(autoincrement())
  imageUrl String
  category String  // "INTERIOR", "CUISINE", "EVENTS"
  caption  String?
}

model Hours {
  id          Int      @id @default(autoincrement())
  dayOfWeek   String   // "Monday", "Tuesday", etc. သို့မဟုတ် "Daily"
  shiftName   String?  // "Lunch", "Dinner", "All Day"
  openTime    String   // "12:00 PM"
  closeTime   String   // "10:30 PM"
  isClosed    Boolean  @default(false) // ထိုနေ့တွင် ဆိုင်ပိတ်ပါက true
  updatedAt   DateTime @updatedAt
}

